<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="FileGrouper.Views.MainWindow"
        x:CompileBindings="False"
        Width="1320"
        Height="840"
        MinWidth="1080"
        MinHeight="720"
        Title="{Binding WindowTitle}"
        FontFamily="Avenir Next, Helvetica Neue, Segoe UI"
        Background="#EDF2F8">
  <Window.Resources>
    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#F8FBFF" Offset="0.0" />
      <GradientStop Color="#EEF3FA" Offset="0.62" />
      <GradientStop Color="#EAF0F9" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#112942" Offset="0" />
      <GradientStop Color="#1B3B5E" Offset="0.55" />
      <GradientStop Color="#2B5C8B" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="ShellBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F4F8FF" />
    <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#F8FBFF" />
    <SolidColorBrush x:Key="BorderBrush" Color="#D9E2EF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#5D708A" />
    <SolidColorBrush x:Key="BodyTextBrush" Color="#243750" />
    <SolidColorBrush x:Key="TitleTextBrush" Color="#1A2D45" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2B6FE8" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#2059BD" />
    <SolidColorBrush x:Key="PositiveBrush" Color="#2D8D65" />
    <SolidColorBrush x:Key="WarningBrush" Color="#9C6A1E" />
    <SolidColorBrush x:Key="DangerBrush" Color="#C24848" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Border.ShellCard">
      <Setter Property="Background" Value="{DynamicResource ShellBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="BoxShadow" Value="0 10 24 0 #120B1A2B" />
    </Style>

    <Style Selector="Border.Card">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="14" />
    </Style>

    <Style Selector="Border.SoftCard">
      <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
      <Setter Property="BorderBrush" Value="#DEE6F3" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="10" />
    </Style>

    <Style Selector="Border.MetricCard">
      <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
      <Setter Property="BorderBrush" Value="#D3DEEF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="11" />
    </Style>

    <Style Selector="TextBlock.PageTitle">
      <Setter Property="FontSize" Value="30" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TitleTextBrush}" />
    </Style>

    <Style Selector="TextBlock.SubtleText">
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#C8D6EA" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#C8D6EA" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
      <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="Button.PrimaryAction">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentDarkBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="16,10" />
    </Style>

    <Style Selector="Button.PrimaryAction:pointerover">
      <Setter Property="Background" Value="#367BF3" />
    </Style>

    <Style Selector="Button.SecondaryAction">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#29415F" />
      <Setter Property="BorderBrush" Value="#C5D4EA" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="12,9" />
    </Style>

    <Style Selector="Button.SecondaryAction:pointerover">
      <Setter Property="Background" Value="#F4F8FF" />
    </Style>

    <Style Selector="TabItem">
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#4C617D" />
    </Style>

    <Style Selector="TabItem:selected">
      <Setter Property="Foreground" Value="#1D3656" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.RowSpan="3" Background="{DynamicResource AppBackgroundBrush}" />

    <Border Grid.Row="0"
            Margin="18,18,18,10"
            Background="{DynamicResource HeroBrush}"
            BorderBrush="#406388"
            BorderThickness="1"
            CornerRadius="18"
            Padding="18"
            BoxShadow="0 14 30 0 #1A0A182B">
      <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
        <StackPanel Spacing="6">
          <TextBlock Classes="PageTitle" Text="{Binding PageTitle}" />
          <TextBlock Foreground="#BFD2EA"
                     Text="{Binding PageSubtitle}" />
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <TextBlock VerticalAlignment="Center" Foreground="#C4D8EE" Text="{Binding LanguageLabel}" />
            <ComboBox Width="130"
                      ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <TextBlock VerticalAlignment="Center" Foreground="#C4D8EE" Text="{Binding SafeModeLabel}" />
            <ToggleSwitch IsChecked="{Binding IsDryRun}"
                          OnContent="{Binding DryRunOnText}"
                          OffContent="{Binding DryRunOffText}" />
          </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0" ColumnDefinitions="*,*,*" ColumnSpacing="10">
          <Border Classes="SoftCard" Background="#1A395A" BorderBrush="#40698D">
            <StackPanel>
              <TextBlock Foreground="#AFC8E3" Text="{Binding ProgressTitle}" />
              <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold"
                         Text="{Binding ProgressPercent, StringFormat='{}{0:0}%'}" />
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Classes="SoftCard" Background="#1A395A" BorderBrush="#40698D">
            <StackPanel>
              <TextBlock Foreground="#AFC8E3" Text="{Binding TotalFilesLabel}" />
              <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding TotalFiles}" />
            </StackPanel>
          </Border>

          <Border Grid.Column="2" Classes="SoftCard" Background="#1A395A" BorderBrush="#40698D">
            <StackPanel>
              <TextBlock Foreground="#AFC8E3" Text="{Binding ReclaimableLabel}" />
              <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding ReclaimableSize}" />
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          Margin="18,0,18,10"
          ColumnDefinitions="390,*"
          ColumnSpacing="14">
      <Border Grid.Column="0" Classes="ShellCard">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="14">
            <Border Classes="Card">
              <StackPanel Spacing="10">
                <TextBlock Classes="SectionTitle" Text="{Binding WorkspaceTitle}" />
                <TextBlock Classes="SubtleText" Text="{Binding WorkspaceSubtitle}" />

                <StackPanel Spacing="6">
                  <TextBlock Foreground="#27405D" Text="{Binding SourceFolderLabel, StringFormat='1. {0}'}" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox Text="{Binding SourcePath}" Watermark="{Binding SourceWatermark}" />
                    <Button Grid.Column="1"
                            Classes="SecondaryAction"
                            Click="BrowseSourceClick"
                            Content="{Binding BrowseButtonText}" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="6">
                  <TextBlock Foreground="#27405D" Text="{Binding TargetFolderLabel, StringFormat='2. {0}'}" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox Text="{Binding TargetPath}" Watermark="{Binding TargetWatermark}" />
                    <Button Grid.Column="1"
                            Classes="SecondaryAction"
                            Click="BrowseTargetClick"
                            Content="{Binding BrowseButtonText}" />
                  </Grid>
                </StackPanel>

                <Border Classes="SoftCard">
                  <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Foreground="#1E3654" Text="{Binding PathValidationTitle}" />
                    <TextBlock Classes="SubtleText" TextWrapping="Wrap" Text="{Binding PathValidationText}" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <Border Classes="Card">
              <StackPanel Spacing="10">
                <TextBlock Classes="SectionTitle" Text="{Binding OperationOutputTitle, StringFormat='3. {0}'}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="SubtleText" Text="{Binding OrganizationModeLabel}" />
                    <ComboBox ItemsSource="{Binding OrganizationModes}"
                              SelectedItem="{Binding SelectedOrganizationMode}" />
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Classes="SubtleText" Text="{Binding DuplicateModeLabel}" />
                    <ComboBox ItemsSource="{Binding DedupeModes}"
                              SelectedItem="{Binding SelectedDedupeMode}" />
                  </StackPanel>
                </Grid>

                <StackPanel Spacing="6">
                  <TextBlock Classes="SubtleText" Text="{Binding ExecutionScopeLabel}" />
                  <ComboBox ItemsSource="{Binding ExecutionScopes}"
                            SelectedItem="{Binding SelectedExecutionScope}" />
                </StackPanel>

                <TextBlock Classes="SubtleText" TextWrapping="Wrap" Text="{Binding OperationOutputLine1}" />
                <TextBlock Classes="SubtleText" TextWrapping="Wrap" Text="{Binding OperationOutputLine2}" />
              </StackPanel>
            </Border>

            <Expander Header="{Binding FiltersTitle}" IsExpanded="False">
              <Border Margin="0,8,0,0" Classes="Card">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="SubtleText" Text="{Binding IncludeExtLabel}" />
                      <TextBox Text="{Binding IncludeExtensionsText}" Watermark=".jpg, .png" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                      <TextBlock Classes="SubtleText" Text="{Binding ExcludeExtLabel}" />
                      <TextBox Text="{Binding ExcludeExtensionsText}" Watermark=".tmp, .cache" />
                    </StackPanel>
                  </Grid>

                  <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="SubtleText" Text="{Binding MinSizeLabel}" />
                      <TextBox Text="{Binding MinSizeMbText}" Watermark="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                      <TextBlock Classes="SubtleText" Text="{Binding MaxSizeLabel}" />
                      <TextBox Text="{Binding MaxSizeMbText}" Watermark="10240" />
                    </StackPanel>
                  </Grid>

                  <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="SubtleText" Text="{Binding FromDateLabel}" />
                      <TextBox Text="{Binding FromDateText}" Watermark="2025-01-01" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                      <TextBlock Classes="SubtleText" Text="{Binding ToDateLabel}" />
                      <TextBox Text="{Binding ToDateText}" Watermark="2026-12-31" />
                    </StackPanel>
                  </Grid>

                  <CheckBox Content="{Binding ExcludeHiddenLabel}" IsChecked="{Binding ExcludeHiddenFiles}" />
                  <CheckBox Content="{Binding ExcludeSystemLabel}" IsChecked="{Binding ExcludeSystemFiles}" />
                  <CheckBox Content="{Binding SimilarImagesLabel}" IsChecked="{Binding DetectSimilarImages}" />
                </StackPanel>
              </Border>
            </Expander>

            <Expander Header="{Binding ProfilesTitle}" IsExpanded="False">
              <Border Margin="0,8,0,0" Classes="Card">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <ComboBox ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfileName}" />
                    <Button Grid.Column="1"
                            Classes="SecondaryAction"
                            Command="{Binding ApplyProfileCommand}"
                            Content="{Binding ApplyProfileButtonText}" />
                  </Grid>

                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox Text="{Binding NewProfileName}" Watermark="{Binding ProfileNameLabel}" />
                    <Button Grid.Column="1"
                            Classes="SecondaryAction"
                            Command="{Binding SaveProfileCommand}"
                            Content="{Binding SaveProfileButtonText}" />
                  </Grid>
                </StackPanel>
              </Border>
            </Expander>

            <Border Classes="Card">
              <StackPanel Spacing="8">
                <TextBlock Classes="SectionTitle" Text="{Binding ApplyButtonText, StringFormat='4. {0}'}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                  <Button Classes="PrimaryAction"
                          Command="{Binding PreviewCommand}"
                          Content="{Binding PreviewButtonText}" />
                  <Button Grid.Column="1"
                          Classes="PrimaryAction"
                          Command="{Binding ApplyCommand}"
                          Content="{Binding ApplyButtonText}" />
                </Grid>

                <Button Classes="SecondaryAction"
                        Command="{Binding SwapPathsCommand}"
                        Content="{Binding SwapButtonText}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                  <Button Classes="SecondaryAction"
                          Command="{Binding PauseResumeCommand}"
                          Content="{Binding PauseResumeButtonText}" />
                  <Button Grid.Column="1"
                          Classes="SecondaryAction"
                          Command="{Binding CancelCommand}"
                          Content="{Binding CancelButtonText}" />
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                  <Button Classes="SecondaryAction"
                          Command="{Binding UndoCommand}"
                          Content="{Binding UndoButtonText}" />
                  <Button Grid.Column="1"
                          Classes="SecondaryAction"
                          Command="{Binding ExportReportCommand}"
                          Content="{Binding ExportReportButtonText}" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="12">
        <Border Classes="ShellCard">
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Classes="SectionTitle" Text="{Binding ProgressTitle}" />
              <TextBlock Grid.Column="1" Classes="SubtleText"
                         Text="{Binding ProgressPercent, StringFormat='{}{0:0}%'}" />
            </Grid>

            <TextBlock Classes="SubtleText" Text="{Binding ProgressStatus}" />
            <ProgressBar Value="{Binding ProgressPercent}" Minimum="0" Maximum="100" Height="10" />

            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
              <Border Classes="MetricCard">
                <StackPanel Spacing="2">
                  <TextBlock Classes="SubtleText" Text="{Binding TotalFilesLabel}" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="#203754" Text="{Binding TotalFiles}" />
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Classes="MetricCard">
                <StackPanel Spacing="2">
                  <TextBlock Classes="SubtleText" Text="{Binding TotalSizeLabel}" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="#203754" Text="{Binding TotalSize}" />
                </StackPanel>
              </Border>

              <Border Grid.Column="2" Classes="MetricCard">
                <StackPanel Spacing="2">
                  <TextBlock Classes="SubtleText" Text="{Binding DuplicateFilesLabel}" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" Text="{Binding DuplicateFiles}" />
                </StackPanel>
              </Border>

              <Border Grid.Row="1" Classes="MetricCard">
                <StackPanel Spacing="2">
                  <TextBlock Classes="SubtleText" Text="{Binding ReclaimableLabel}" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PositiveBrush}" Text="{Binding ReclaimableSize}" />
                </StackPanel>
              </Border>

              <Border Grid.Row="1" Grid.Column="1" Classes="MetricCard">
                <StackPanel Spacing="2">
                  <TextBlock Classes="SubtleText" Text="{Binding ErrorsLabel}" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" Text="{Binding ErrorCount}" />
                </StackPanel>
              </Border>

              <Border Grid.Row="1" Grid.Column="2" Classes="MetricCard">
                <StackPanel Spacing="2">
                  <TextBlock Classes="SubtleText" Text="{Binding SimilarImagesLabel}" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="#2E5E97" Text="{Binding SimilarImageGroups}" />
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="ShellCard">
          <TabControl>
            <TabItem Header="{Binding DuplicateGroupsTitle}">
              <Grid Margin="8" RowDefinitions="Auto,*" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                  <TextBlock Classes="SubtleText" Text="{Binding GroupsSummary}" />
                  <TextBlock Grid.Column="1" Classes="SubtleText" Text="{Binding CopiedSummary}" />
                  <TextBlock Grid.Column="2" Classes="SubtleText" Text="{Binding MovedSummary}" />
                  <TextBlock Grid.Column="3" Classes="SubtleText" Text="{Binding QuarantinedSummary}" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
                  <Border Classes="SoftCard">
                    <Grid RowDefinitions="Auto,*" RowSpacing="8">
                      <TextBlock Classes="SectionTitle" Text="{Binding DuplicateGroupsTitle}" />
                      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DuplicateItems}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Margin="0,0,0,8"
                                      Padding="10"
                                      Background="#FFFFFF"
                                      CornerRadius="8"
                                      BorderBrush="#D1DDF0"
                                      BorderThickness="1">
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10">
                                  <TextBlock Foreground="#355A83" FontWeight="SemiBold" Text="{Binding HashPrefix}" />
                                  <TextBlock Grid.Column="1" Foreground="{DynamicResource WarningBrush}" Text="{Binding RemoveCount, StringFormat='x{0}'}" />
                                  <TextBlock Grid.Column="2" TextTrimming="CharacterEllipsis" Foreground="#30445F" Text="{Binding KeepPath}" />
                                  <TextBlock Grid.Column="3" Foreground="{DynamicResource PositiveBrush}" Text="{Binding FileSize}" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </Grid>
                  </Border>

                  <Border Grid.Column="1" Classes="SoftCard">
                    <Grid RowDefinitions="Auto,*" RowSpacing="8">
                      <TextBlock Classes="SectionTitle" Text="{Binding SimilarImagesLabel}" />
                      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SimilarImageItems}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Margin="0,0,0,8"
                                      Padding="10"
                                      Background="#FFFFFF"
                                      CornerRadius="8"
                                      BorderBrush="#D1DDF0"
                                      BorderThickness="1">
                                <TextBlock Classes="SubtleText" Text="{Binding .}" />
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </Grid>
                  </Border>
                </Grid>
              </Grid>
            </TabItem>

            <TabItem Header="{Binding LogStreamTitle}">
              <Grid Margin="8" RowDefinitions="Auto,*" RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBlock Classes="SectionTitle" Text="{Binding LogStreamTitle}" />
                  <Button Grid.Column="1"
                          Classes="SecondaryAction"
                          Command="{Binding ClearLogsCommand}"
                          Content="{Binding ClearButtonText}" />
                </Grid>

                <Border Grid.Row="1" Classes="SoftCard">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogLines}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Margin="0,0,0,6"
                                     FontFamily="Menlo, Consolas, monospace"
                                     FontSize="12"
                                     Foreground="#3A4F68"
                                     Text="{Binding .}" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
              </Grid>
            </TabItem>

            <TabItem Header="{Binding QuickStartTitle}">
              <ScrollViewer Margin="8" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                  <Border Classes="SoftCard">
                    <StackPanel Spacing="5">
                      <TextBlock Classes="SectionTitle" Text="{Binding QuickStartTitle}" />
                      <TextBlock Classes="SubtleText" Text="{Binding QuickStartLine1}" />
                      <TextBlock Classes="SubtleText" Text="{Binding QuickStartLine2}" />
                      <TextBlock Classes="SubtleText" Text="{Binding QuickStartLine3}" />
                    </StackPanel>
                  </Border>

                  <Border Classes="SoftCard">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="SectionTitle" Text="{Binding ExportReportButtonText}" />
                      <TextBlock Classes="SubtleText" TextWrapping="Wrap" Text="{Binding ReportStatus}" />
                    </StackPanel>
                  </Border>

                  <Border Classes="SoftCard">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="SectionTitle" Text="{Binding ModeExplanationText}" />
                      <TextBlock Classes="SubtleText" TextWrapping="Wrap" Text="{Binding OperationOutputLine1}" />
                      <TextBlock Classes="SubtleText" TextWrapping="Wrap" Text="{Binding OperationOutputLine2}" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Row="2"
            Margin="18,0,18,18"
            Padding="12,9"
            Classes="ShellCard">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="14">
        <TextBlock VerticalAlignment="Center" Foreground="#1E3551" Text="{Binding Status}" />
        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   Classes="SubtleText"
                   Text="{Binding LastRunDisplay}" />
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock VerticalAlignment="Center"
                     Classes="SubtleText"
                     Text="{Binding BusyLabel}"
                     IsVisible="{Binding IsBusy}" />
          <ProgressBar Width="110" Height="8" IsVisible="{Binding IsBusy}" IsIndeterminate="True" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
